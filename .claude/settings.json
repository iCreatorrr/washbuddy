{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash)",
      "Bash(git stash push:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git stash pop)",
      "Bash(git stash pop:*)",

      "Bash(npm install)",
      "Bash(npm install --save:*)",
      "Bash(npm install --save-dev:*)",
      "Bash(npm ci)",
      "Bash(npm run:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm list)",
      "Bash(npm list:*)",
      "Bash(npm ls)",
      "Bash(npm ls:*)",

      "Bash(pnpm install)",
      "Bash(pnpm install --filter:*)",
      "Bash(pnpm install --save:*)",
      "Bash(pnpm install --save-dev:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm list)",
      "Bash(pnpm list:*)",
      "Bash(pnpm ls)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm -r:*)",

      "Bash(yarn install)",
      "Bash(yarn run:*)",
      "Bash(yarn test)",
      "Bash(yarn test:*)",
      "Bash(yarn list)",
      "Bash(yarn list:*)",

      "Bash(tsx:*)",
      "Bash(ts-node:*)",
      "Bash(node:*)",
      "Bash(npx tsx:*)",
      "Bash(npx ts-node:*)",

      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(file:*)",

      "Bash(tsc)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- :*)",
      "Bash(git checkout .)",
      "Bash(git rebase:*)",

      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",

      "Bash(npm install -g:*)",
      "Bash(npm install --global:*)",
      "Bash(npm i -g:*)",
      "Bash(pnpm install -g:*)",
      "Bash(pnpm install --global:*)",
      "Bash(pnpm add -g:*)",
      "Bash(pnpm add --global:*)",
      "Bash(yarn global:*)",

      "Bash(prisma migrate deploy:*)",
      "Bash(prisma db push:*)",
      "Bash(npx prisma migrate deploy:*)",
      "Bash(npx prisma db push:*)",
      "Bash(pnpm exec prisma migrate deploy:*)",
      "Bash(pnpm exec prisma db push:*)",

      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(terraform:*)",
      "Bash(vercel:*)",
      "Bash(netlify:*)",
      "Bash(fly:*)",
      "Bash(flyctl:*)"
    ]
  }
}
