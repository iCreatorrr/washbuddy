generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserMembershipRole {
  DRIVER
  FLEET_ADMIN
  DISPATCHER
  MAINTENANCE_MANAGER
  READ_ONLY_ANALYST
  PROVIDER_ADMIN
  PROVIDER_STAFF
  PLATFORM_SUPER_ADMIN
  PLATFORM_SUPPORT_ADMIN
  PLATFORM_OPS_ADMIN
}

enum BookingStatus {
  REQUESTED
  HELD
  PROVIDER_CONFIRMED
  PROVIDER_DECLINED
  EXPIRED
  CUSTOMER_CANCELLED
  PROVIDER_CANCELLED
  LATE
  NO_SHOW
  CHECKED_IN
  IN_SERVICE
  COMPLETED_PENDING_WINDOW
  COMPLETED
  DISPUTED
  REFUNDED
  SETTLED
}

enum PaymentStatus {
  AUTHORIZATION_PENDING
  AUTHORIZED
  CAPTURED
  VOIDED
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  CUSTOMER_UPHELD
  PROVIDER_UPHELD
  PARTIAL_RESOLUTION
  CLOSED
}

enum BillingMode {
  FLEET_PAYS
  DRIVER_PAYS
  MIXED
}

enum FleetStatus {
  ACTIVE
  SUSPENDED
  ONBOARDING
}

enum WashRequestStatus {
  REQUEST_CREATED
  PENDING_FLEET_APPROVAL
  MODIFIED_PENDING_DRIVER_CONFIRMATION
  AUTO_APPROVED
  APPROVED_BOOKING_PENDING_PROVIDER
  DECLINED
  EXPIRED
  CANCELLED_BY_DRIVER
  CONVERTED_TO_BOOKING
  FAILED_NO_SLOT_AVAILABLE
  FAILED_POLICY_BLOCKED
}

enum WashRequestType {
  STRUCTURED
  FLEXIBLE
}

enum RecurringCadenceType {
  EVERY_X_DAYS
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum GeneratedTaskState {
  PENDING
  BOOKING_ATTEMPTED
  BOOKED
  EXCEPTION
  SKIPPED
}

enum NotificationChannel {
  SMS
  EMAIL
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

// ─── USERS ──────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  phoneE164       String?   @unique @map("phone_e164")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  passwordHash    String?   @map("password_hash")
  isActive        Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  smsVerifiedAt   DateTime? @map("sms_verified_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  accountType     String?   @map("account_type") // "customer" | "provider" | "fleet_admin"
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  fleetMemberships     FleetMembership[]
  providerMemberships  ProviderMembership[]
  platformRoles        UserPlatformRole[]
  vehiclesOwned        Vehicle[]               @relation("vehicle_owner")
  bookingsAsCustomer   Booking[]               @relation("booking_customer")
  reviewsAuthored      Review[]                @relation("review_author")
  reviewsReceived      Review[]                @relation("review_subject")
  reviewVotes          ReviewVote[]
  disputesOpened       Dispute[]               @relation("dispute_opened_by")
  notifications        Notification[]
  uploadedFiles        FileAsset[]
  auditEvents          AuditEvent[]            @relation("audit_actor")
  driverAssignments    FleetDriverAssignment[] @relation("driver_assignments")
  washRequestsAsDriver WashRequest[]           @relation("wash_request_driver")
  washRequestRevisions WashRequestRevision[]   @relation("wash_request_revision_actor")
  washRequestMessages  WashRequestMessage[]    @relation("wash_request_message_author")
  // V2 relations
  bookingPhotos           BookingPhoto[]          @relation("photo_uploader")
  bookingMessages         BookingMessage[]        @relation("message_sender")
  washNotes               WashNote[]              @relation("note_author")
  clientProfiles          ClientProfile[]         @relation("client_profiles")
  notificationPreferences NotificationPreference[]
  assignedBookings        Booking[]               @relation("booking_operator")
  purchasedSubscriptions  FleetSubscription[]     @relation("subscription_purchaser")

  @@index([isActive])
  @@map("users")
}

// ─── FLEETS ─────────────────────────────────────────────────────────────────

model Fleet {
  id                       String      @id @default(uuid()) @db.Uuid
  name                     String
  status                   FleetStatus @default(ACTIVE)
  billingMode              BillingMode @map("billing_mode")
  currencyCode             String      @map("currency_code") @db.Char(3)
  defaultTimezone          String      @default("America/New_York") @map("default_timezone")
  requireVehicleAssignMins Int         @default(30) @map("require_vehicle_assign_mins")
  requestPolicyJson        Json        @default("{}") @map("request_policy_json")
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  memberships       FleetMembership[]
  vehicles          Vehicle[]
  depots            FleetDepot[]
  vehicleGroups     FleetVehicleGroup[]
  driverAssignments FleetDriverAssignment[]
  washRequests      WashRequest[]
  recurringPrograms FleetRecurringProgram[]
  policyOverrides   FleetPolicyOverride[]
  subscriptions     FleetSubscription[]

  @@map("fleets")
}

model FleetMembership {
  id        String             @id @default(uuid()) @db.Uuid
  fleetId   String             @map("fleet_id") @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  role      UserMembershipRole
  isActive  Boolean            @default(true) @map("is_active")
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  fleet Fleet @relation(fields: [fleetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([fleetId, userId])
  @@index([userId])
  @@map("fleet_memberships")
}

model UserPlatformRole {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  role      UserMembershipRole
  isActive  Boolean            @default(true) @map("is_active")
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@map("user_platform_roles")
}

// ─── FLEET DEPOTS ──────────────────────────────────────────────────────────

model FleetDepot {
  id                             String   @id @default(uuid()) @db.Uuid
  fleetId                        String   @map("fleet_id") @db.Uuid
  name                           String
  timezone                       String
  addressLine1                   String?  @map("address_line_1")
  city                           String?
  regionCode                     String?  @map("region_code")
  postalCode                     String?  @map("postal_code")
  countryCode                    String?  @map("country_code") @db.Char(2)
  defaultProviderPreferencesJson Json     @default("{}") @map("default_provider_preferences_json")
  isActive                       Boolean  @default(true) @map("is_active")
  createdAt                      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  fleet             Fleet                   @relation(fields: [fleetId], references: [id])
  vehicles          Vehicle[]               @relation("vehicle_depot")
  recurringPrograms FleetRecurringProgram[]

  @@index([fleetId])
  @@map("fleet_depots")
}

// ─── FLEET VEHICLE GROUPS ──────────────────────────────────────────────────

model FleetVehicleGroup {
  id           String   @id @default(uuid()) @db.Uuid
  fleetId      String   @map("fleet_id") @db.Uuid
  name         String
  criteriaJson Json     @default("{}") @map("criteria_json")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  fleet             Fleet                         @relation(fields: [fleetId], references: [id])
  members           FleetVehicleGroupMembership[]
  recurringPrograms FleetRecurringProgram[]       @relation("recurring_program_vehicle_group")

  @@unique([fleetId, name])
  @@map("fleet_vehicle_groups")
}

model FleetVehicleGroupMembership {
  id             String   @id @default(uuid()) @db.Uuid
  vehicleGroupId String   @map("vehicle_group_id") @db.Uuid
  vehicleId      String   @map("vehicle_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  vehicleGroup FleetVehicleGroup @relation(fields: [vehicleGroupId], references: [id], onDelete: Cascade)
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id])

  @@unique([vehicleGroupId, vehicleId])
  @@map("fleet_vehicle_group_memberships")
}

// ─── FLEET DRIVER ASSIGNMENTS ──────────────────────────────────────────────

model FleetDriverAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  fleetId      String    @map("fleet_id") @db.Uuid
  vehicleId    String    @map("vehicle_id") @db.Uuid
  driverUserId String    @map("driver_user_id") @db.Uuid
  startsAt     DateTime  @map("starts_at") @db.Timestamptz
  endsAt       DateTime? @map("ends_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  fleet   Fleet   @relation(fields: [fleetId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  User    @relation("driver_assignments", fields: [driverUserId], references: [id])

  @@index([fleetId])
  @@index([vehicleId])
  @@index([driverUserId])
  @@map("fleet_driver_assignments")
}

// ─── WASH REQUESTS ─────────────────────────────────────────────────────────

model WashRequest {
  id                     String            @id @default(uuid()) @db.Uuid
  fleetId                String            @map("fleet_id") @db.Uuid
  vehicleId              String            @map("vehicle_id") @db.Uuid
  driverUserId           String            @map("driver_user_id") @db.Uuid
  requestType            WashRequestType   @map("request_type")
  status                 WashRequestStatus @default(REQUEST_CREATED)
  desiredProviderId      String?           @map("desired_provider_id") @db.Uuid
  desiredLocationId      String?           @map("desired_location_id") @db.Uuid
  desiredStartAtUtc      DateTime?         @map("desired_start_at_utc") @db.Timestamptz
  desiredServiceIdsJson  Json?             @map("desired_service_ids_json")
  timeWindowCode         String?           @map("time_window_code")
  notes                  String?
  approvedProviderId     String?           @map("approved_provider_id") @db.Uuid
  approvedLocationId     String?           @map("approved_location_id") @db.Uuid
  approvedStartAtUtc     DateTime?         @map("approved_start_at_utc") @db.Timestamptz
  approvedServiceIdsJson Json?             @map("approved_service_ids_json")
  approvalNotes          String?           @map("approval_notes")
  declineReasonCode      String?           @map("decline_reason_code")
  declineNotes           String?           @map("decline_notes")
  linkedBookingId        String?           @unique @map("linked_booking_id") @db.Uuid
  expiresAtUtc           DateTime?         @map("expires_at_utc") @db.Timestamptz
  idempotencyKey         String            @unique @map("idempotency_key")
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  fleet            Fleet                 @relation(fields: [fleetId], references: [id])
  vehicle          Vehicle               @relation(fields: [vehicleId], references: [id])
  driver           User                  @relation("wash_request_driver", fields: [driverUserId], references: [id])
  desiredProvider  Provider?             @relation("wash_request_desired_provider", fields: [desiredProviderId], references: [id])
  desiredLocation  Location?             @relation("wash_request_desired_location", fields: [desiredLocationId], references: [id])
  approvedProvider Provider?             @relation("wash_request_approved_provider", fields: [approvedProviderId], references: [id])
  approvedLocation Location?             @relation("wash_request_approved_location", fields: [approvedLocationId], references: [id])
  linkedBooking    Booking?              @relation("wash_request_booking", fields: [linkedBookingId], references: [id])
  revisions        WashRequestRevision[]
  thread           WashRequestThread?

  @@index([fleetId, status])
  @@index([driverUserId])
  @@index([vehicleId])
  @@map("wash_requests")
}

model WashRequestRevision {
  id                 String   @id @default(uuid()) @db.Uuid
  washRequestId      String   @map("wash_request_id") @db.Uuid
  revisionNo         Int      @map("revision_no")
  changedByUserId    String   @map("changed_by_user_id") @db.Uuid
  beforeSnapshotJson Json     @map("before_snapshot_json")
  afterSnapshotJson  Json     @map("after_snapshot_json")
  changeReasonCode   String   @map("change_reason_code")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  washRequest WashRequest @relation(fields: [washRequestId], references: [id])
  changedBy   User        @relation("wash_request_revision_actor", fields: [changedByUserId], references: [id])

  @@unique([washRequestId, revisionNo])
  @@map("wash_request_revisions")
}

model WashRequestThread {
  id            String   @id @default(uuid()) @db.Uuid
  washRequestId String   @unique @map("wash_request_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  washRequest WashRequest          @relation(fields: [washRequestId], references: [id])
  messages    WashRequestMessage[]

  @@map("wash_request_threads")
}

model WashRequestMessage {
  id           String   @id @default(uuid()) @db.Uuid
  threadId     String   @map("thread_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  thread WashRequestThread @relation(fields: [threadId], references: [id])
  author User              @relation("wash_request_message_author", fields: [authorUserId], references: [id])

  @@index([threadId, createdAt])
  @@map("wash_request_messages")
}

// ─── FLEET RECURRING PROGRAMS ──────────────────────────────────────────────

model FleetRecurringProgram {
  id                  String               @id @default(uuid()) @db.Uuid
  fleetId             String               @map("fleet_id") @db.Uuid
  name                String
  scopeType           String               @map("scope_type")
  scopeDepotId        String?              @map("scope_depot_id") @db.Uuid
  scopeVehicleGroupId String?              @map("scope_vehicle_group_id") @db.Uuid
  cadenceType         RecurringCadenceType @map("cadence_type")
  cadenceConfigJson   Json                 @map("cadence_config_json")
  servicePolicyJson   Json                 @map("service_policy_json")
  providerPolicyJson  Json                 @map("provider_policy_json")
  horizonDays         Int                  @default(30) @map("horizon_days")
  isActive            Boolean              @default(false) @map("is_active")
  lastGeneratedAt     DateTime?            @map("last_generated_at") @db.Timestamptz
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  fleet             Fleet                @relation(fields: [fleetId], references: [id])
  scopeDepot        FleetDepot?          @relation(fields: [scopeDepotId], references: [id])
  scopeVehicleGroup FleetVehicleGroup?   @relation("recurring_program_vehicle_group", fields: [scopeVehicleGroupId], references: [id])
  generatedTasks    FleetGeneratedTask[]

  @@index([fleetId])
  @@map("fleet_recurring_programs")
}

model FleetGeneratedTask {
  id                 String             @id @default(uuid()) @db.Uuid
  recurringProgramId String             @map("recurring_program_id") @db.Uuid
  vehicleId          String             @map("vehicle_id") @db.Uuid
  dueAtUtc           DateTime           @map("due_at_utc") @db.Timestamptz
  generationState    GeneratedTaskState @default(PENDING) @map("generation_state")
  linkedBookingId    String?            @unique @map("linked_booking_id") @db.Uuid
  exceptionReason    String?            @map("exception_reason")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  recurringProgram FleetRecurringProgram @relation(fields: [recurringProgramId], references: [id])
  vehicle          Vehicle               @relation(fields: [vehicleId], references: [id])
  linkedBooking    Booking?              @relation("generated_task_booking", fields: [linkedBookingId], references: [id])

  @@index([recurringProgramId])
  @@index([vehicleId, dueAtUtc])
  @@map("fleet_generated_tasks")
}

// ─── FLEET POLICY OVERRIDES ────────────────────────────────────────────────

model FleetPolicyOverride {
  id         String   @id @default(uuid()) @db.Uuid
  fleetId    String   @map("fleet_id") @db.Uuid
  scopeType  String   @map("scope_type")
  scopeId    String   @map("scope_id") @db.Uuid
  policyJson Json     @map("policy_json")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  fleet Fleet @relation(fields: [fleetId], references: [id])

  @@unique([fleetId, scopeType, scopeId])
  @@map("fleet_policy_overrides")
}

// ─── PROVIDERS ──────────────────────────────────────────────────────────────

model Provider {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String
  externalPayoutAcctId String?   @unique @map("stripe_connected_acct_id")
  payoutReady          Boolean   @default(false) @map("payout_ready")
  isActive             Boolean   @default(true) @map("is_active")
  approvalStatus       String    @default("PENDING") @map("approval_status") // PENDING, APPROVED, REJECTED, SUSPENDED
  approvedAt           DateTime? @map("approved_at") @db.Timestamptz
  approvedBy           String?   @map("approved_by") @db.Uuid
  rejectionReason      String?   @map("rejection_reason")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  memberships          ProviderMembership[]
  locations            Location[]
  payoutBatches        ProviderPayoutBatch[]
  responseMetrics      ProviderResponseMetric[]
  washRequestsDesired  WashRequest[]            @relation("wash_request_desired_provider")
  washRequestsApproved WashRequest[]            @relation("wash_request_approved_provider")
  // V2 relations
  clientProfiles       ClientProfile[]
  discounts            ProviderDiscount[]
  subscriptionPackages SubscriptionPackage[]

  @@index([isActive])
  @@index([approvalStatus])
  @@map("providers")
}

model ProviderMembership {
  id         String             @id @default(uuid()) @db.Uuid
  providerId String             @map("provider_id") @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  locationId String?            @map("location_id") @db.Uuid
  role       UserMembershipRole
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  provider Provider  @relation(fields: [providerId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([providerId, userId, locationId])
  @@index([userId])
  @@map("provider_memberships")
}

// ─── PROVIDER RESPONSE METRICS ─────────────────────────────────────────────

model ProviderResponseMetric {
  id              String   @id @default(uuid()) @db.Uuid
  providerId      String   @map("provider_id") @db.Uuid
  locationId      String   @map("location_id") @db.Uuid
  periodStart     DateTime @map("period_start") @db.Timestamptz
  periodEnd       DateTime @map("period_end") @db.Timestamptz
  totalRequests   Int      @default(0) @map("total_requests")
  respondedInSla  Int      @default(0) @map("responded_in_sla")
  missedSla       Int      @default(0) @map("missed_sla")
  avgResponseSecs Int?     @map("avg_response_secs")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  provider Provider @relation(fields: [providerId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([providerId, locationId, periodStart])
  @@map("provider_response_metrics")
}

// ─── LOCATIONS ──────────────────────────────────────────────────────────────

model Location {
  id                     String   @id @default(uuid()) @db.Uuid
  providerId             String   @map("provider_id") @db.Uuid
  name                   String
  timezone               String
  addressLine1           String   @map("address_line_1")
  addressLine2           String?  @map("address_line_2")
  city                   String
  regionCode             String   @map("region_code")
  postalCode             String   @map("postal_code")
  countryCode            String   @map("country_code") @db.Char(2)
  latitude               Decimal  @db.Decimal(9, 6)
  longitude              Decimal  @db.Decimal(9, 6)
  responseSlaUnder1hMins Int      @default(5) @map("response_sla_under_1h_mins")
  responseSlaFutureMins  Int      @default(15) @map("response_sla_future_mins")
  bookingBufferMins      Int      @default(5) @map("booking_buffer_mins")
  isVisible              Boolean  @default(false) @map("is_visible")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  provider             Provider                 @relation(fields: [providerId], references: [id])
  services             Service[]
  operatingWindows     OperatingWindow[]
  bookings             Booking[]
  bookingHolds         BookingHold[]
  providerMemberships  ProviderMembership[]
  reviews              Review[]
  responseMetrics      ProviderResponseMetric[]
  washRequestsDesired  WashRequest[]            @relation("wash_request_desired_location")
  washRequestsApproved WashRequest[]            @relation("wash_request_approved_location")
  // V2 relations
  washBays             WashBay[]
  washNotes            WashNote[]
  discounts            ProviderDiscount[]
  subscriptionPackages SubscriptionPackage[]

  @@index([providerId])
  @@index([isVisible])
  @@index([isVisible, providerId])
  @@index([latitude, longitude])
  @@map("locations")
}

model OperatingWindow {
  id         String   @id @default(uuid()) @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  dayOfWeek  Int      @map("day_of_week")
  openTime   String   @map("open_time")
  closeTime  String   @map("close_time")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, dayOfWeek, openTime])
  @@map("operating_windows")
}

// ─── VEHICLES ───────────────────────────────────────────────────────────────

model Vehicle {
  id               String    @id @default(uuid()) @db.Uuid
  fleetId          String?   @map("fleet_id") @db.Uuid
  ownerUserId      String?   @map("owner_user_id") @db.Uuid
  depotId          String?   @map("depot_id") @db.Uuid
  categoryCode     String    @map("category_code")
  subtypeCode      String    @map("subtype_code")
  lengthInches     Int       @map("length_inches")
  heightInches     Int       @map("height_inches")
  hasRestroom      Boolean   @default(false) @map("has_restroom")
  unitNumber       String    @map("unit_number")
  licensePlate     String?   @map("license_plate")
  lastWashAtUtc    DateTime? @map("last_wash_at_utc") @db.Timestamptz
  nextWashDueAtUtc DateTime? @map("next_wash_due_at_utc") @db.Timestamptz
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  fleet                   Fleet?                        @relation(fields: [fleetId], references: [id])
  owner                   User?                         @relation("vehicle_owner", fields: [ownerUserId], references: [id])
  depot                   FleetDepot?                   @relation("vehicle_depot", fields: [depotId], references: [id])
  bookings                Booking[]
  driverAssignments       FleetDriverAssignment[]
  washRequests            WashRequest[]
  vehicleGroupMemberships FleetVehicleGroupMembership[]
  generatedTasks          FleetGeneratedTask[]
  subscriptions           FleetSubscription[]

  @@index([fleetId])
  @@index([ownerUserId])
  @@index([depotId])
  @@map("vehicles")
}

// ─── SERVICES ───────────────────────────────────────────────────────────────

model Service {
  id                   String   @id @default(uuid()) @db.Uuid
  locationId           String   @map("location_id") @db.Uuid
  name                 String
  description          String?
  durationMins         Int      @map("duration_mins")
  basePriceMinor       Int      @map("base_price_minor")
  currencyCode         String   @map("currency_code") @db.Char(3)
  platformFeeMinor     Int      @map("platform_fee_minor")
