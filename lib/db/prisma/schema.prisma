  initiatedBy      String?  @map("initiated_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  paymentIntent PaymentIntentInternal @relation(fields: [paymentIntentId], references: [id])

  @@index([paymentIntentId])
  @@map("refunds_internal")
}

// ─── PROVIDER PAYOUTS ───────────────────────────────────────────────────────

model ProviderPayoutBatch {
