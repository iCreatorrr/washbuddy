  leadTimeMins         Int      @default(60) @map("lead_time_mins")
  requiresConfirmation Boolean  @default(true) @map("requires_confirmation")
  isVisible            Boolean  @default(false) @map("is_visible")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  location           Location               @relation(fields: [locationId], references: [id])
  compatibilityRules ServiceCompatibility[]
  bookings           Booking[]
  bookingHolds       BookingHold[]

  @@index([locationId])
  @@index([isVisible])
