}

model ServiceCompatibility {
  id              String  @id @default(uuid()) @db.Uuid
  serviceId       String  @map("service_id") @db.Uuid
  categoryCode    String  @map("category_code")
  subtypeCode     String? @map("subtype_code")
  maxLengthInches Int?    @map("max_length_inches")
  maxHeightInches Int?    @map("max_height_inches")

  service Service @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, categoryCode, subtypeCode])
