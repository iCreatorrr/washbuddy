}

// ─── BOOKING HOLDS ──────────────────────────────────────────────────────────

model BookingHold {
  id             String   @id @default(uuid()) @db.Uuid
  locationId     String   @map("location_id") @db.Uuid
  serviceId      String   @map("service_id") @db.Uuid
  slotStartAtUtc DateTime @map("slot_start_at_utc") @db.Timestamptz
  slotEndAtUtc   DateTime @map("slot_end_at_utc") @db.Timestamptz
  expiresAtUtc   DateTime @map("expires_at_utc") @db.Timestamptz
  bookingId      String?  @map("booking_id") @db.Uuid
  requestId      String   @map("request_id")
  userId         String   @map("user_id") @db.Uuid
  isReleased     Boolean  @default(false) @map("is_released")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([locationId, slotStartAtUtc, expiresAtUtc])
  @@map("booking_holds")
}

// ─── BOOKINGS ───────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id @default(uuid()) @db.Uuid
  locationId            String        @map("location_id") @db.Uuid
  serviceId             String        @map("service_id") @db.Uuid
  customerId            String        @map("customer_id") @db.Uuid
  vehicleId             String?       @map("vehicle_id") @db.Uuid
  fleetPlaceholderClass String?       @map("fleet_placeholder_class")
  status                BookingStatus @default(REQUESTED)
  idempotencyKey        String        @unique @map("idempotency_key")

  serviceNameSnapshot   String @map("service_name_snapshot")
  serviceBasePriceMinor Int    @map("service_base_price_minor")
  platformFeeMinor      Int    @map("platform_fee_minor")
  totalPriceMinor       Int    @map("total_price_minor")
  taxAmountMinor        Int    @default(0) @map("tax_amount_minor")
  currencyCode          String @map("currency_code") @db.Char(3)
  locationTimezone      String @map("location_timezone")

  scheduledStartAtUtc         DateTime  @map("scheduled_start_at_utc") @db.Timestamptz
  scheduledEndAtUtc           DateTime  @map("scheduled_end_at_utc") @db.Timestamptz
  providerResponseDeadlineUtc DateTime? @map("provider_response_deadline_utc") @db.Timestamptz
  bookingHoldExpiresUtc       DateTime? @map("booking_hold_expires_utc") @db.Timestamptz

  customerArrivedAtUtc    DateTime? @map("customer_arrived_at_utc") @db.Timestamptz
  providerCheckedInAtUtc  DateTime? @map("provider_checked_in_at_utc") @db.Timestamptz
  serviceStartedAtUtc     DateTime? @map("service_started_at_utc") @db.Timestamptz
  serviceCompletedAtUtc   DateTime? @map("service_completed_at_utc") @db.Timestamptz
  completionWindowEndsUtc DateTime? @map("completion_window_ends_utc") @db.Timestamptz

  declineReasonCode      String?   @map("decline_reason_code")
  cancellationReasonCode String?   @map("cancellation_reason_code")
  reminderSentAt         DateTime? @map("reminder_sent_at") @db.Timestamptz

  // V2 fields
  bookingSource              String    @default("PLATFORM") @map("booking_source")       // PLATFORM, DIRECT, WALK_IN
  isOffPlatform              Boolean   @default(false) @map("is_off_platform")
  offPlatformClientName      String?   @map("off_platform_client_name")
  offPlatformClientPhone     String?   @map("off_platform_client_phone")
  offPlatformClientEmail     String?   @map("off_platform_client_email")
  offPlatformPaymentExternal Boolean   @default(false) @map("off_platform_payment_external")
  washBayId                  String?   @map("wash_bay_id") @db.Uuid
  assignedOperatorId         String?   @map("assigned_operator_id") @db.Uuid
  discountAmountMinor        Int       @default(0) @map("discount_amount_minor")
  discountDescription        String?   @map("discount_description")
  additionalServiceIds       String[]  @default([]) @map("additional_service_ids")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  location       Location                @relation(fields: [locationId], references: [id])
  service        Service                 @relation(fields: [serviceId], references: [id])
  customer       User                    @relation("booking_customer", fields: [customerId], references: [id])
  vehicle        Vehicle?                @relation(fields: [vehicleId], references: [id])
  statusHistory  BookingStatusHistory[]
  paymentIntents PaymentIntentInternal[]
  holds          BookingHold[]
  reviews        Review[]
  disputes       Dispute[]
  payoutItems    ProviderPayoutItem[]
  washRequest    WashRequest?            @relation("wash_request_booking")
  generatedTask  FleetGeneratedTask?     @relation("generated_task_booking")
  // V2 relations
  washBay          WashBay?         @relation("booking_bay", fields: [washBayId], references: [id])
  assignedOperator User?            @relation("booking_operator", fields: [assignedOperatorId], references: [id])
  photos           BookingPhoto[]
  messages         BookingMessage[]
  washNotes        WashNote[]

  @@index([locationId, scheduledStartAtUtc, scheduledEndAtUtc, status])
  @@index([customerId])
  @@index([status])
  @@index([vehicleId])
  @@index([status, providerResponseDeadlineUtc])
  @@index([bookingSource])
  @@index([washBayId])
  @@index([assignedOperatorId])
  @@map("bookings")
}

model BookingStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  bookingId  String         @map("booking_id") @db.Uuid
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus  @map("to_status")
  changedBy  String?        @map("changed_by") @db.Uuid
  reason     String?
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@map("booking_status_history")
}

// ─── PAYMENTS ───────────────────────────────────────────────────────────────

model PaymentIntentInternal {
  id                  String        @id @default(uuid()) @db.Uuid
  bookingId           String        @map("booking_id") @db.Uuid
