# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string (used by Prisma and session store)
DATABASE_URL=postgresql://user:password@localhost:5432/washbuddy

# ─── Server ──────────────────────────────────────────────────────
# Port for the API server
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# ─── Session ─────────────────────────────────────────────────────
# Secret for signing session cookies (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ─── Frontend ────────────────────────────────────────────────────
# Base path for the frontend (set by Replit)
BASE_PATH=/

# ─── Email (Future) ─────────────────────────────────────────────
# SMTP configuration (not yet active — emailService.ts logs to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@washbuddy.com

# ─── Stripe (stubs active when empty — set keys for live payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
